#!/bin/sh
#
# Interim substitute for server-side branch protection.
#
# GitHub gates branch protection and rulesets behind a paid plan for private
# repositories, so `main` cannot be protected server-side until the repo is
# public (Phase 15). This hook enforces the same two rules locally.
#
# It lives in .githooks/ and is committed, so it survives a fresh clone once
# `git config core.hooksPath .githooks` has been run — see the README.
#
# This is a local gate, not real protection: `--no-verify` bypasses it, and it
# does nothing for anyone who has not configured the hooks path.

set -e

protected_branch="main"
remote_ref_prefix="refs/heads/"

fail() {
  printf '\n  pre-push: %s\n\n' "$1" >&2
  exit 1
}

while read -r local_ref local_sha remote_ref remote_sha; do
  branch="${remote_ref#$remote_ref_prefix}"
  [ "$branch" = "$protected_branch" ] || continue

  # Deleting the branch.
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    fail "refusing to delete $protected_branch"
  fi

  # A non-fast-forward push rewrites published history.
  if [ "$remote_sha" != "0000000000000000000000000000000000000000" ]; then
    if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
      fail "refusing to force-push $protected_branch (would discard remote history)"
    fi
  fi

  # Mirror the CI gate so main is never pushed red.
  printf '  pre-push: running tests before pushing to %s…\n' "$protected_branch"
  npm test >/dev/null 2>&1 || fail "tests are failing; not pushing to $protected_branch"
  npm run validate:data >/dev/null 2>&1 || fail "dataset validation failed; not pushing"
  printf '  pre-push: checks passed.\n'
done

exit 0
